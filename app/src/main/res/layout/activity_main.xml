<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/colorBackground"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:paddingHorizontal="20dp">

            <!-- Title row -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="30sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif"
                android:letterSpacing="-0.02"
                android:textColor="?attr/colorOnSurface" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="14dp"
                android:text="@string/app_subtitle"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <!-- Search bar — flat tinted pill, no elevation (modern iOS/Pixel style) -->
            <LinearLayout
                android:id="@+id/searchCard"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_search_surface"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="@null" />

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:paddingStart="12dp"
                    android:paddingEnd="0dp"
                    android:hint="@string/search_hint"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Content area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Result count -->
        <TextView
            android:id="@+id/tvResultCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.03"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:text="" />

        <LinearLayout
            android:id="@+id/collectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvCollectionsLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/collections"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.01"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/colorOnSurface" />

            <ImageButton
                android:id="@+id/btnAddCollection"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_input_add"
                app:tint="?attr/colorPrimary"
                android:contentDescription="@string/create_collection" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCollections"
            android:layout_width="match_parent"
            android:layout_height="128dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:scrollbars="none"
            android:paddingHorizontal="12dp"
            android:clipToPadding="false" />

        <TextView
            android:id="@+id/screenshotsSectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="8dp"
            android:text="@string/screenshots_section"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.01"
            android:fontFamily="sans-serif-medium"
            android:textColor="?attr/colorOnSurface" />

        <!-- Loading -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:visibility="gone"
            android:indeterminate="true"
            app:trackThickness="3dp"
            app:trackCornerRadius="2dp"
            app:trackColor="@android:color/transparent"
            app:indicatorColor="?attr/colorPrimary" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:paddingHorizontal="48dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_image_placeholder"
                android:alpha="0.25"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tvEmptyMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/no_indexed_images"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center"
                android:lineSpacingExtra="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/empty_subtitle"
                android:textSize="13sp"
                android:textColor="?attr/colorOutline"
                android:gravity="center" />

        </LinearLayout>

        <!-- Staggered image grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvImages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingHorizontal="6dp"
            android:paddingTop="4dp"
            android:paddingBottom="16dp"
            android:scrollbars="none"
            android:visibility="visible" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
