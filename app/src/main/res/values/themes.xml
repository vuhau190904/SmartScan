<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryContainer">@color/color_primary_container</item>
        <item name="colorOnPrimary">@color/color_on_primary</item>
        <item name="colorOnPrimaryContainer">@color/color_on_primary_container</item>
        <item name="colorSecondary">@color/color_secondary</item>
        <item name="colorSecondaryContainer">@color/color_secondary_container</item>
        <item name="colorTertiary">@color/color_tertiary</item>
        <item name="colorTertiaryContainer">@color/color_tertiary_container</item>
        <item name="android:colorBackground">@color/color_background</item>
        <item name="colorSurface">@color/color_surface</item>
        <item name="colorSurfaceVariant">@color/color_surface_variant</item>
        <item name="colorOnSurface">@color/color_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/color_on_surface_variant</item>
        <item name="colorOutline">@color/color_outline</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/color_background</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.SmartScan.MaterialAlertDialog</item>
    </style>

    <style name="Theme.MyApplication" parent="Base.Theme.MyApplication" />

    <!-- Material Alert: bo góc lớn, nút kiểu chữ, bớt “mặc định Android cũ” -->
    <style name="ThemeOverlay.SmartScan.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.SmartScan.AlertDialog</item>
    </style>

    <style name="ShapeAppearance.SmartScan.AlertDialog" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">22dp</item>
    </style>

    <style name="Widget.SmartScan.TextInput.Note" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="boxBackgroundMode">filled</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
    </style>
</resources>
